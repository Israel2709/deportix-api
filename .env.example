# ------------------------------------------------------------------------------
# Deportix API — environment variables
# Copy to .env.local for local development. NEVER commit real values.
# ------------------------------------------------------------------------------

# Firebase Admin SDK (server-only). Obtain from a Firebase service account JSON:
#   project_id    -> FIREBASE_PROJECT_ID
#   client_email  -> FIREBASE_CLIENT_EMAIL
#   private_key   -> FIREBASE_PRIVATE_KEY
#
# IMPORTANT (private key newlines):
#   - Local .env.local: wrap the value in double quotes and keep the literal \n
#     escapes, e.g. FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#   - Vercel: paste the key with REAL newlines into the dashboard secret.
#   The app normalizes \n -> newline at runtime, so both forms work.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional — CORS allow-list. Default is "*" (public read-only MVP).
# Set a comma-separated list of origins to restrict later, e.g.:
#   CORS_ALLOWED_ORIGINS=https://deportix-portal.vercel.app,https://deportix.com
CORS_ALLOWED_ORIGINS=*
